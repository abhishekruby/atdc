# ─────────────────────────────────────────────────────────
# GOOGLE SHEETS API (Service Account)
# ─────────────────────────────────────────────────────────
# 1. Go to Google Cloud Console → IAM & Admin → Service Accounts
# 2. Create a service account, generate a JSON key
# 3. Share your Google Sheet with the service account email (Editor role)
# 4. Paste values below from the JSON key file

GOOGLE_SHEETS_CLIENT_EMAIL=
# Paste the private_key value from the JSON file. 
# IMPORTANT: Replace literal newlines with \n
GOOGLE_SHEETS_PRIVATE_KEY=

# The ID of your Google Sheet
GOOGLE_SHEET_ID=

# Tab names — must match EXACTLY the tab names in your Google Sheet
GOOGLE_APPOINTMENTS_TAB=
GOOGLE_HOME_COLLECTION_TAB=
GOOGLE_CONTACT_REQUEST=

# ─────────────────────────────────────────────────────────
# META WHATSAPP CLOUD API
# ─────────────────────────────────────────────────────────
# 1. Go to developers.facebook.com → Your App → WhatsApp → API Setup
# 2. Copy the temporary or permanent Access Token
# 3. Copy the Phone Number ID (NOT the phone number itself)

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Admin WhatsApp number in E.164 format (no + sign, no spaces)
# Example: 919876543210
ADMIN_WHATSAPP_NUMBER=

# ─────────────────────────────────────────────────────────
# WHATSAPP MESSAGE TEMPLATES
# ─────────────────────────────────────────────────────────
# Set the exact template names approved on Meta Business Manager
WHATSAPP_TEMPLATE_CONFIRMED=
WHATSAPP_TEMPLATE_REJECTED=
WHATSAPP_TEMPLATE_LANGUAGE=en

# ─────────────────────────────────────────────────────────
# DEVELOPMENT / TESTING
# ─────────────────────────────────────────────────────────
# Set to "true" to send free-form text messages instead of templates (dev only)
WHATSAPP_USE_FREE_TEXT=false

# ─────────────────────────────────────────────────────────
# WEBHOOK SECURITY
# ─────────────────────────────────────────────────────────
# Verify token for Meta webhook handshake
VERIFY_TOKEN=

# ─────────────────────────────────────────────────────────
# CRON JOB SECURITY
# ─────────────────────────────────────────────────────────
# Protects system endpoints from unauthorized calls
CRON_SECRET=

# ─────────────────────────────────────────────────────────
# WHATSAPP AI CHATBOT
# ─────────────────────────────────────────────────────────
# Get a Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# The public URL of your app
NEXT_PUBLIC_APP_URL=

# Public WhatsApp number for user interaction
NEXT_PUBLIC_WHATSAPP_NUMBER=
